# ================================================
# MedPharma Plus - Storefront Environment Variables
# Copy this to .env.local and fill in your values
# ================================================

# Medusa Backend URL
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://your-backend.up.railway.app

# Storefront Base URL
NEXT_PUBLIC_BASE_URL=https://your-storefront.up.railway.app

# Default Region
NEXT_PUBLIC_DEFAULT_REGION=ge

# Revalidation Secret (for ISR)
REVALIDATE_SECRET=your-revalidate-secret

# Production
NODE_ENV=production
PORT=8000
