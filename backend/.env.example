# ================================================
# MedPharma Plus - Backend Environment Variables
# Copy this to .env and fill in your values
# ================================================

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# Redis (Railway)
REDIS_URL=redis://default:password@host:port

# Security Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here
COOKIE_SECRET=your-cookie-secret-here

# CORS Configuration (replace with your Railway domains)
STORE_CORS=https://your-storefront.up.railway.app
ADMIN_CORS=https://your-backend.up.railway.app
AUTH_CORS=https://your-storefront.up.railway.app,https://your-backend.up.railway.app

# Cloudflare R2 File Storage
S3_FILE_URL=https://your-bucket.r2.dev
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=auto
S3_BUCKET=your-bucket-name
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# Resend Email Service
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=MedPharma Plus

# Production
NODE_ENV=production
PORT=9000
